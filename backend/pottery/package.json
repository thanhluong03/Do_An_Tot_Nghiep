{
  "name": "pottery",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:validation": "node run-smart-tests.js",
    "test:product": "npx jest src/product/product-simple.spec.ts --verbose",
    "test:order": "npx jest src/order/order-simple.spec.ts --verbose",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migrate:run": "npm run typeorm migration:run -- -d ./typeOrm.config.ts",
    "migrate:revert": "npm run typeorm migration:revert -- -d ./typeOrm.config.ts",
    "migrate:create": "npm run typeorm -- migration:create ./libs/database/src/migrations/$npm_config_name",
    "migrate:generate": "npm run typeorm migration:generate -- -d ./typeOrm.config.ts ./libs/database/src/migrations/auto-generated-migration"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.8",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.8",
    "@types/bcrypt": "^6.0.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.9",
    "passport-google-oauth20": "^2.0.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "pg": "^8.16.3",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.26",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/auth(|/.*)$": "<rootDir>/libs/auth/src/$1",
      "^@app/cart_item(|/.*)$": "<rootDir>/libs/cart_item/src/$1",
      "^@app/category(|/.*)$": "<rootDir>/libs/category/src/$1",
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/conversation(|/.*)$": "<rootDir>/libs/conversation/src/$1",
      "^@app/customer(|/.*)$": "<rootDir>/libs/customer/src/$1",
      "^@app/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@app/delivery_proof(|/.*)$": "<rootDir>/libs/delivery_proof/src/$1",
      "^@app/driver_location(|/.*)$": "<rootDir>/libs/driver_location/src/$1",
      "^@app/geocoding(|/.*)$": "<rootDir>/libs/geocoding/src/$1",
      "^@app/import_product(|/.*)$": "<rootDir>/libs/import_product/src/$1",
      "^@app/inventory(|/.*)$": "<rootDir>/libs/inventory/src/$1",
      "^@app/login(|/.*)$": "<rootDir>/libs/login/src/$1",
      "^@app/news(|/.*)$": "<rootDir>/libs/news/src/$1",
      "^@app/order(|/.*)$": "<rootDir>/libs/order/src/$1",
      "^@app/paymenttransaction(|/.*)$": "<rootDir>/libs/paymenttransaction/src/$1",
      "^@app/permission(|/.*)$": "<rootDir>/libs/permission/src/$1",
      "^@app/product(|/.*)$": "<rootDir>/libs/product/src/$1",
      "^@app/promotion(|/.*)$": "<rootDir>/libs/promotion/src/$1",
      "^@app/review(|/.*)$": "<rootDir>/libs/review/src/$1",
      "^@app/role(|/.*)$": "<rootDir>/libs/role/src/$1",
      "^@app/send_mail(|/.*)$": "<rootDir>/libs/send_mail/src/$1",
      "^@app/store(|/.*)$": "<rootDir>/libs/store/src/$1",
      "^@app/supplier(|/.*)$": "<rootDir>/libs/supplier/src/$1",
      "^@app/user(|/.*)$": "<rootDir>/libs/user/src/$1",
      "^@app/voucher(|/.*)$": "<rootDir>/libs/voucher/src/$1",
      "^@app/import_request(|/.*)$": "<rootDir>/libs/import_request/src/$1"
    }
  }
}
