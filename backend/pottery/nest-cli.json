{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "permission": {
      "type": "library",
      "root": "libs/permission",
      "entryFile": "index",
      "sourceRoot": "libs/permission/src",
      "compilerOptions": {
        "tsConfigPath": "libs/permission/tsconfig.lib.json"
      }
    },
    "product": {
      "type": "library",
      "root": "libs/product",
      "entryFile": "index",
      "sourceRoot": "libs/product/src",
      "compilerOptions": {
        "tsConfigPath": "libs/product/tsconfig.lib.json"
      }
    },
    "role": {
      "type": "library",
      "root": "libs/role",
      "entryFile": "index",
      "sourceRoot": "libs/role/src",
      "compilerOptions": {
        "tsConfigPath": "libs/role/tsconfig.lib.json"
      }
    },
    "store": {
      "type": "library",
      "root": "libs/store",
      "entryFile": "index",
      "sourceRoot": "libs/store/src",
      "compilerOptions": {
        "tsConfigPath": "libs/store/tsconfig.lib.json"
      }
    },
    "supplier": {
      "type": "library",
      "root": "libs/supplier",
      "entryFile": "index",
      "sourceRoot": "libs/supplier/src",
      "compilerOptions": {
        "tsConfigPath": "libs/supplier/tsconfig.lib.json"
      }
    },
    "user": {
      "type": "library",
      "root": "libs/user",
      "entryFile": "index",
      "sourceRoot": "libs/user/src",
      "compilerOptions": {
        "tsConfigPath": "libs/user/tsconfig.lib.json"
      }
    }
  }
}