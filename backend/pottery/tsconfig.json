{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/common": [
        "libs/common/src"
      ],
      "@app/common/*": [
        "libs/common/src/*"
      ],
      "@app/database": [
        "libs/database/src"
      ],
      "@app/database/*": [
        "libs/database/src/*"
      ],
      "@app/permission": [
        "libs/permission/src"
      ],
      "@app/permission/*": [
        "libs/permission/src/*"
      ],
      "@app/product": [
        "libs/product/src"
      ],
      "@app/product/*": [
        "libs/product/src/*"
      ],
      "@app/promotion": [
        "libs/promotion/src"
      ],
      "@app/promotion/*": [
        "libs/promotion/src/*"
      ],
      "@app/review": [
        "libs/review/src"
      ],
      "@app/review/*": [
        "libs/review/src/*"
      ],
      "@app/role": [
        "libs/role/src"
      ],
      "@app/role/*": [
        "libs/role/src/*"
      ],
      "@app/store": [
        "libs/store/src"
      ],
      "@app/store/*": [
        "libs/store/src/*"
      ],
      "@app/supplier": [
        "libs/supplier/src"
      ],
      "@app/supplier/*": [
        "libs/supplier/src/*"
      ],
      "@app/user": [
        "libs/user/src"
      ],
      "@app/user/*": [
        "libs/user/src/*"
      ],
      "@app/flashsale": [
        "libs/flashsale/src"
      ],
      "@app/flashsale/*": [
        "libs/flashsale/src/*"
      ]
    }
  }
}