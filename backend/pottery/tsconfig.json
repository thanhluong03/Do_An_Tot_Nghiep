{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/cart_item": [
        "libs/cart_item/src"
      ],
      "@app/category": [
        "libs/category/src"
      ],
      "@app/category/*": [
        "libs/category/src/*"
      ],
      "@app/common": [
        "libs/common/src"
      ],
      "@app/common/*": [
        "libs/common/src/*"
      ],
      "@app/conversation": [
        "libs/conversation/src"
      ],
      "@app/conversation/*": [
        "libs/conversation/src/*"
      ],
      "@app/customer": [
        "libs/customer/src"
      ],
      "@app/customer/*": [
        "libs/customer/src/*"
      ],
      "@app/database": [
        "libs/database/src"
      ],
      "@app/database/*": [
        "libs/database/src/*"
      ],
      "@app/delivery_proof": [
        "libs/delivery_proof/src"
      ],
      "@app/delivery_proof/*": [
        "libs/delivery_proof/src/*"
      ],
      "@app/driver_location": [
        "libs/driver_location/src"
      ],
      "@app/driver_location/*": [
        "libs/driver_location/src/*"
      ],
      "@app/geocoding": [
        "libs/geocoding/src"
      ],
      "@app/geocoding/*": [
        "libs/geocoding/src/*"
      ],
      "@app/import_product": [
        "libs/import_product/src"
      ],
      "@app/import_product/*": [
        "libs/import_product/src/*"
      ],
      "@app/inventory": [
        "libs/inventory/src"
      ],
      "@app/inventory/*": [
        "libs/inventory/src/*"
      ],
      "@app/login": [
        "libs/login/src"
      ],
      "@app/login/*": [
        "libs/login/src/*"
      ],
      "@app/news": [
        "libs/news/src"
      ],
      "@app/news/*": [
        "libs/news/src/*"
      ],
      "@app/order": [
        "libs/order/src"
      ],
      "@app/order/*": [
        "libs/order/src/*"
      ],
      "@app/paymenttransaction": [
        "libs/paymenttransaction/src"
      ],
      "@app/paymenttransaction/*": [
        "libs/paymenttransaction/src/*"
      ],
      "@app/permission": [
        "libs/permission/src"
      ],
      "@app/permission/*": [
        "libs/permission/src/*"
      ],
      "@app/product": [
        "libs/product/src"
      ],
      "@app/product/*": [
        "libs/product/src/*"
      ],
      "@app/promotion": [
        "libs/promotion/src"
      ],
      "@app/promotion/*": [
        "libs/promotion/src/*"
      ],
      "@app/review": [
        "libs/review/src"
      ],
      "@app/review/*": [
        "libs/review/src/*"
      ],
      "@app/role": [
        "libs/role/src"
      ],
      "@app/role/*": [
        "libs/role/src/*"
      ],
      "@app/send_mail": [
        "libs/send_mail/src"
      ],
      "@app/send_mail/*": [
        "libs/send_mail/src/*"
      ],
      "@app/store": [
        "libs/store/src"
      ],
      "@app/store/*": [
        "libs/store/src/*"
      ],
      "@app/supplier": [
        "libs/supplier/src"
      ],
      "@app/supplier/*": [
        "libs/supplier/src/*"
      ],
      "@app/user": [
        "libs/user/src"
      ],
      "@app/user/*": [
        "libs/user/src/*"
      ],
      "@app/voucher": [
        "libs/voucher/src"
      ],
      "@app/voucher/*": [
        "libs/voucher/src/*"
      ],
      "@app/auth": [
        "libs/auth/src"
      ],
      "@app/auth/*": [
        "libs/auth/src/*"
      ]
    }
  }
}